# Copy this file to .env for local testing. Never commit the real .env.
# In GitHub, these same three names go in Settings > Secrets and variables > Actions.

# Your personal ClickUp API token.
# Get it at: ClickUp > your avatar > Settings > Apps > Generate under API Token.
CLICKUP_API_TOKEN=YOUR_CLICKUP_TOKEN_HERE

# List IDs holding items waiting on Leah's sign off.
# Open the list in ClickUp; the ID is the number in the URL after /li/
# More than one list is fine: separate with commas, no spaces needed.
APPROVALS_LIST_IDS=YOUR_APPROVALS_LIST_ID_HERE

# List IDs for the revenue pipeline (enrollment, partnerships).
# Comma separated if the pipeline lives in more than one list.
REVENUE_LIST_IDS=YOUR_REVENUE_LIST_ID_HERE
